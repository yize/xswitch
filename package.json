{
  "name": "xswitch",
  "version": "2.0.0",
  "description": "Xswitch - A compact proxy tool based on Chrome extensions (Vue 3 + Vite)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": "https://github.com/yize/xswitch.git",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.2.6",
    "monaco-editor": "^0.55.1",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/chrome": "^0.2.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^15.0.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.1.0",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "^3.4.12"
    }
  }
}
